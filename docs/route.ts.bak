import { NextRequest, NextResponse } from 'next/server';

// In-memory storage (for development)
// In production, replace with database or Google Sheets
let registrations: Array<{
  name: string;
  email: string;
  phone?: string;
  college?: string;
  timestamp: string;
}> = [];

export async function POST(request: NextRequest) {
  try {
    const body = await request.json();
    const { name, email, phone, college } = body;

    // Validate required fields
    if (!name || !email) {
      return NextResponse.json(
        { error: 'Name and email are required' },
        { status: 400 }
      );
    }

    // Validate email format
    const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
    if (!emailRegex.test(email)) {
      return NextResponse.json(
        { error: 'Invalid email format' },
        { status: 400 }
      );
    }

    // Create registration record
    const registration = {
      name,
      email,
      phone: phone || '',
      college: college || '',
      timestamp: new Date().toISOString(),
    };

    // Store registration
    registrations.push(registration);

    // TODO: Integrate with Google Sheets
    // Use the following code to integrate with Google Sheets:
    /*
    const sheets = google.sheets({ version: 'v4', auth: getAuth() });
    await sheets.spreadsheets.values.append({
      spreadsheetId: process.env.GOOGLE_SHEETS_ID,
      range: 'A1',
      valueInputOption: 'USER_ENTERED',
      requestBody: {
        values: [[name, email, phone, college, new Date().toISOString()]],
      },
    });
    */

    console.log(`[v0] New registration: ${name} (${email})`);
    console.log(`[v0] Total registrations: ${registrations.length}`);

    return NextResponse.json(
      {
        success: true,
        message: 'Registration successful',
        uniqueId: `WS${Date.now()}`,
      },
      { status: 201 }
    );
  } catch (error) {
    console.error('[v0] Registration error:', error);
    return NextResponse.json(
      { error: 'Registration failed' },
      { status: 500 }
    );
  }
}

export async function GET() {
  // For development - view all registrations
  if (process.env.NODE_ENV === 'development') {
    return NextResponse.json({
      total: registrations.length,
      registrations,
    });
  }

  return NextResponse.json({ error: 'Not found' }, { status: 404 });
}
